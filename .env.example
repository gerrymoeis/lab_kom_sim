# =============================================================================
# SIMLABKOM — Environment Configuration
# Copy file ini ke .env dan sesuaikan dengan server Anda.
# JANGAN commit .env ke git! File ini berisi secrets.
# =============================================================================

# --- Application Mode --------------------------------------------------------
ENVIRONMENT=production              # "development" atau "production"

# --- Server ------------------------------------------------------------------
HOST=0.0.0.0                        # Bind address (0.0.0.0 = semua interface)
PORT=8080                           # Port HTTP

# --- Database ----------------------------------------------------------------
# Single-lab: isi DATABASE_PATH. Multi-lab: isi LABS_<N>_* (abaikan DATABASE_PATH).
# Untuk PostgreSQL/Neon: tambahkan DATABASE_URL (menggantikan SQLite).
DATABASE_PATH=inventaris_lab.db     # Single-lab: path file SQLite

GLOBAL_DB_PATH=data/global.db       # Path database global (users, permissions)

# Multi-lab format (recommended) — setiap lab terisolasi 4 baris:
#   LABS_<N>_ID    → ID lab (seed folder: seeds/<lowercase(ID)>/)
#   LABS_<N>_DB    → path file SQLite database
#   LABS_<N>_TITLE → display name di UI
#   LABS_<N>_URL   → slug untuk routing (contoh: lab-kom-mi)
# Untuk delete lab: comment 4 baris LABS_<N>_* (via Admin Panel).
# Untuk add lab: copy blok dengan N berikutnya, restart server.
LABS_1_ID=MI-1
LABS_1_DB=data/lab_mi_1.db
LABS_1_TITLE=Lab Kom MI 1
LABS_1_URL=lab-kom-mi
LABS_2_ID=VOKASI-1
LABS_2_DB=data/lab_vokasi_1.db
LABS_2_TITLE=Lab Kom Vokasi
LABS_2_URL=vokasi

# Format LABS lama (deprecated — masih didukung, tapi gunakan format baru di atas):
# LABS=MI-1:data/lab_mi_1.db:Lab Kom MI 1:lab-kom-mi,VOKASI-1:data/lab_vokasi_1.db:Lab Kom Vokasi:vokasi

#DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require

# --- Session & Cookie --------------------------------------------------------
SESSION_SECRET=change-this-secret-in-production-to-random-string
COOKIE_SECURE=false                 # true hanya jika pakai HTTPS

# --- Upload ------------------------------------------------------------------
UPLOAD_PATH=uploads                 # Folder upload (per-lab: uploads/{urlPath}/)
# Gunakan absolute path di production agar data tidak hilang saat deploy.
# Contoh: UPLOAD_PATH=/opt/simlab/app/current/uploads

# --- Write Mode --------------------------------------------------------------
WRITE_MODE=sync                     # "sync" (langsung) atau "async" (queue-based batch)

# --- Timezone ----------------------------------------------------------------
TIMEZONE=Asia/Jakarta               # IANA timezone (Asia/Jakarta, Asia/Makassar, dll)

# --- Android Mode ------------------------------------------------------------
ANDROID=false                       # true untuk Termux/Android (client-side compress)

# --- Pagination --------------------------------------------------------------
DEFAULT_PAGE_SIZE=25                # Default item per halaman untuk semua list

# --- Log Retention -----------------------------------------------------------
LOG_RETENTION_DAYS=90               # Hapus log activity yang lebih lama dari N hari
LOG_CLEANUP_INTERVAL=24             # Interval pembersihan log (jam)

# --- Auto-Backup (SQLite only) -----------------------------------------------
BACKUP_ENABLED=true                 # Backup otomatis setelah setiap perubahan data
BACKUP_INTERVAL=30                  # Debounce interval (detik) setelah CUD
BACKUP_DIR="./backups"              # Path backup (comma-separated, bisa absolute)
BACKUP_RETENTION=20                 # Maks jumlah backup per lab
BACKUP_MIN_DISK_MB=500              # Minimal disk tersisa (MB) — backup skip jika kurang
BACKUP_COMPRESS=true                # Kompres backup (.zip)

# --- OCR (OpenRouter primary → Gemini fallback) ------------------------------
OPENROUTER_API_KEY=                 # Primary: OpenRouter API key (untuk OCR logbook)
GEMINI_API_KEY=                     # Fallback: Google Gemini API key

# --- PC Photo Seeding (via GitHub Releases) ----------------------------------
# Hanya diperlukan jika ingin seed foto PC dari GitHub Releases.
#PC_PHOTO_RELEASE_URL=https://github.com/owner/repo/releases/download/tag/photos.zip
#GITHUB_TOKEN=                      # GitHub PAT — hanya perlu untuk repo private

# --- Public Site Auto-Build (SSG) — Opsional ---------------------------------
# Membangun static site public setiap ada perubahan data, lalu push ke repo publik.
PUBLIC_BUILD_ENABLED=false
PUBLIC_BUILD_INTERVAL=30            # Debounce interval (detik) setelah CUD
PUBLIC_BUILD_OUT=dist               # Output direktori build
PUBLIC_BUILD_TEMPLATE_DIR=web/templates/public
PUBLIC_BUILD_STATIC_DIR=web/static
PUBLIC_BUILD_REPO_DIR=              # Absolute path ke clone repo publik (untuk auto push)
#PUBLIC_BUILD_REPO_DIR=/opt/simlab/lab_kom_sim_public
PUBLIC_BUILD_BRANCH=main            # Branch repo publik

# Environment Configuration Example
# Copy this file to .env and adjust values as needed

# Application Environment (development, production)
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8080

# Database Configuration (SQLite local)
# Local dev: DATABASE_PATH=inventaris_lab.db
# Production: DATABASE_PATH=/opt/simlab/app/data/inventaris_lab.db
# Database will be stored at this path. In production, use absolute path in /opt/simlab/app/data/
# so all releases share the same database file (no copy on deploy).
DATABASE_PATH=inventaris_lab.db
# PostgreSQL (Neon DB) — set this to use Neon instead of SQLite
DATABASE_URL=postgres://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Write Mode: "sync" (default, langsung ke SQLite) atau "async" (queue-based batch writer)
# Async mode meng-enqueue semua write ke channel buffer, worker batch-process dalam 1 transaksi.
# Berguna untuk menangani burst request tinggi. Default sync (langsung menulis).
WRITE_MODE=sync

# Session Secret (change this in production!)
SESSION_SECRET=change-this-secret-in-production-to-random-string

# Timezone (gunakan IANA time zone database, misal: Asia/Jakarta, Asia/Makassar, Asia/Jayapura)
# "Local" = ikut timezone OS (bisa UTC jika OS tidak dikonfigurasi).
# Default Asia/Jakarta karena project spesifik Indonesia.
TIMEZONE=Asia/Jakarta

# Upload Path
# Local dev: UPLOAD_PATH=uploads
# Production: UPLOAD_PATH=/opt/simlab/app/data/uploads
# Gunakan absolute path di production agar uploads tidak hilang saat deploy (symlink swap).
UPLOAD_PATH=uploads

# Google Gemini API Configuration (fallback)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter API Configuration (primary — do OCR via openrouter/free)
# Supports image understanding with free vision models
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# Android Mode: Set true for Termux/Android deployment (client-side compress)
# Set false or omit for desktop/server deployment (server-side compress)
ANDROID=false

# PC Photo Seeding (via GitHub Releases)
# URL ke ZIP foto PC di GitHub Release
PC_PHOTO_RELEASE_URL=https://github.com/username/pc-photos/releases/download/v1.0.0/photos.zip
# GitHub Personal Access Token (fine-grained, read-only akses ke repo pc-photos)
GITHUB_TOKEN=github_pat_your_token_here

# Default page size for all paginated list views (default: 25)
DEFAULT_PAGE_SIZE=25

# Database Auto-Backup Configuration (SQLite only — skipped for PostgreSQL/Neon)
# Backup is triggered by CUD (Create/Update/Delete) operations, then debounced
# for BACKUP_INTERVAL seconds of inactivity. No periodic backup when idle.
# BACKUP_DIR: comma-separated paths. Use quotes if paths contain spaces.
# Example: BACKUP_DIR="./backups, D:\backup_lab, \\server\share\backup"
BACKUP_ENABLED=true
BACKUP_INTERVAL=30
BACKUP_DIR="./backups, ./backups_secondary"
BACKUP_RETENTION=20
BACKUP_MIN_DISK_MB=500
BACKUP_COMPRESS=true

# SSG Public Site Auto-Build Configuration
# When enabled, any CUD operation triggers a rebuild of the static public site
# after PUBLIC_BUILD_INTERVAL seconds of inactivity, then git pushes to the public repo.
# PUBLIC_BUILD_REPO_DIR must point to a cloned git repo for auto-commit+push.
#
# Testing setup (local dev):
#   PUBLIC_BUILD_ENABLED=true
#   PUBLIC_BUILD_REPO_DIR=C:/path/to/lab_kom_sim_public
#   PUBLIC_BUILD_BRANCH=testing
#   (pastikan branch "testing" sudah ada: git checkout -b testing && git push -u origin testing)
#
# Production setup (server):
#   PUBLIC_BUILD_ENABLED=true
#   PUBLIC_BUILD_REPO_DIR=/opt/simlab/public/repo
#   PUBLIC_BUILD_BRANCH=main
PUBLIC_BUILD_ENABLED=false
PUBLIC_BUILD_INTERVAL=30
PUBLIC_BUILD_OUT=dist
PUBLIC_BUILD_TEMPLATE_DIR=web/templates/public
PUBLIC_BUILD_STATIC_DIR=web/static
PUBLIC_BUILD_REPO_DIR=
PUBLIC_BUILD_BRANCH=main


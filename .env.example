# =============================================================================
# SIMLABKOM — Environment Configuration
# Copy file ini ke .env dan sesuaikan dengan lingkungan Anda.
# Untuk multi-lab: gunakan LABS_<N>_* (format baru). Untuk single-lab: gunakan DATABASE_PATH.
# =============================================================================

# --- Mode Aplikasi -----------------------------------------------------------
ENVIRONMENT=development          # "development" atau "production"

# --- Server ------------------------------------------------------------------
HOST=0.0.0.0                     # Bind address
PORT=8080                        # Port

# --- Database ----------------------------------------------------------------
# Single-lab: isi DATABASE_PATH. Multi-lab: isi LABS_<N>_* (abaikan DATABASE_PATH).
# Untuk PostgreSQL/Neon: isi DATABASE_URL (menggantikan SQLite).
# Production: gunakan absolute path agar data tidak hilang saat deploy.
#   Contoh: DATABASE_PATH=C:\simlab\data\inventaris_lab.db
DATABASE_PATH=inventaris_lab.db  # Single-lab: path file SQLite
GLOBAL_DB_PATH=data/global.db    # Path database global (users, permissions)
# Format LABS baru (recommended) — setiap lab terisolasi 4 baris:
#   LABS_<N>_ID=<LAB-ID>    → ID lab (seed folder: seeds/<lowercase(ID)>/)
#   LABS_<N>_DB=<path>      → path file SQLite database
#   LABS_<N>_TITLE=<title>  → display name di UI
#   LABS_<N>_URL=<slug>     → slug untuk routing (contoh: lab-kom-mi)
# Untuk delete lab: comment 4 baris LABS_<N>_* nya (via UI Admin).
# Untuk add lab: copy blok dengan N berikutnya.
# Contoh:
#LABS_1_ID=MI-1
#LABS_1_DB=data/lab_mi_1.db
#LABS_1_TITLE=Lab Kom MI 1
#LABS_1_URL=lab-kom-mi
#LABS_2_ID=VOKASI-1
#LABS_2_DB=data/lab_vokasi_1.db
#LABS_2_TITLE=Lab Kom Vokasi
#LABS_2_URL=vokasi
# Format LABS lama (deprecated, masih didukung):
# LABS=MI-1:data/lab_mi_1.db:Lab Kom MI 1:lab-kom-mi,VOKASI-1:data/lab_vokasi_1.db:Lab Kom Vokasi:vokasi
#DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require

# --- Session & Cookie --------------------------------------------------------
SESSION_SECRET=change-this-secret-in-production-to-random-string
COOKIE_SECURE=false              # true hanya jika pakai HTTPS

# --- Upload ------------------------------------------------------------------
UPLOAD_PATH=uploads              # Folder upload (per-lab: uploads/{urlPath}/)
# Gunakan absolute path di production agar data tidak hilang saat deploy.

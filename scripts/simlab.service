[Unit]
Description=SIMLab Inventaris Application
Documentation=https://github.com/gerrymoeis/lab_kom_sim
After=network.target

[Service]
Type=simple
User=simlab
Group=simlab
WorkingDirectory=/opt/simlab/app/current
EnvironmentFile=/opt/simlab/.env
ExecStart=/opt/simlab/app/current/app-simlab
Restart=on-failure
RestartSec=5
TimeoutStopSec=15
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
